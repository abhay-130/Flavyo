<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".OnboardingActivity">

    <ImageView
        android:id="@+id/ivBeachScene"
        android:layout_width="232dp"
        android:layout_height="252dp"
        android:layout_marginTop="180dp"
        android:scaleType="centerCrop"
        android:src="@drawable/onboarding_beach_image"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.6"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvZeroWorries"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.09"
        android:textFontWeight="600"
        android:text="ZERO WORRIES. 100% STRAWBERRY."
        android:textColor="@color/flavyo_red"
        android:textSize="18sp"
        android:fontFamily="@font/covered_grace"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/ivBeachScene"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="HardcodedText, UnusedAttribute" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:elevation="2dp"
        android:layout_width="220dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="40dp"
        android:backgroundTint="@color/flavyo_red"
        android:textSize="22sp"
        android:text="Next"
        app:cornerRadius="30dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:textColor="@color/white"
        app:layout_constraintBottom_toTopOf="@id/llDesignerOnboarding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="HardcodedText" />

    <LinearLayout
        android:id="@+id/llDesignerOnboarding"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Design By"
            android:textColor="@color/flavyo_red"
            android:textSize="12sp"
            android:alpha="0.6"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AbhaY"
            android:textColor="@color/flavyo_red"
            android:textSize="12sp"
            android:alpha="0.6"
            android:fontFamily="@font/poppins_semibold"/> </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>